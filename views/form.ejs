<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/styles.css">

    <title>Mini Messageboard</title>
</head>
<body>
    <form method="POST" action="/new">
        <div>
            <label>Enter your name: <input name="user" type="text"></label>
            <label>Write your message: <input name="text" type="text"></label>
        </div>

        <input type="submit" value="Send message">
    </form>
</body>
</html>